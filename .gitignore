# 1. Environment Variables (Sirtaada)
# Kan ayaa qarinaya Password-kaaga MongoDB iyo JWT Secret
.env
.env.local
.env.*.local

# 2. Dependencies
# Kani waa folder-ka ugu weyn ee aan GitHub loo dirin
node_modules/
backend/node_modules/
frontend/node_modules/

# 3. Build outputs
# Folder-ka uu tsc ama vite soo saaro
dist/
backend/dist/
frontend/dist/
build/
.cache/

# 4. OS metadata
# Files-ka uu Mac-gu iska dhex abuuro
.DS_Store
Thumbs.db

# 5. Logs
# Wixii khaladaad ah oo server-ku qoro
npm-debug.log*
yarn-debug.log*
yarn-error.log*
